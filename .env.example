# =============================================================================
# Undercontroll API — Environment Variables Template
# Copy this file to .env and fill in the values for your environment.
# NEVER commit the .env file to version control.
#
# Production recommendation: use AWS Secrets Manager, HashiCorp Vault,
# or your cloud provider's secret management service instead of a .env file.
# =============================================================================

# ── Active Spring Profile ────────────────────────────────────────────────────
# Options: dev | prod
SPRING_PROFILES_ACTIVE=dev

# ── Database ─────────────────────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/undercontroll?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=rabbitmq
RABBITMQ_PASSWORD=your_rabbitmq_password

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret (≥ 256 bits). Example command:
#   openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET_OF_AT_LEAST_256_BITS

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max authentication attempts per minute per IP (brute-force protection)
RATE_LIMIT_AUTH_RPM=10
# Max requests per minute per IP for all other endpoints
RATE_LIMIT_GENERAL_RPM=100

